#!/usr/bin/env bash

# Easier navigation
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ~="cd ~"
alias -- -="cd -"

# Shortcuts
alias dl="cd ~/Downloads"
alias dt="cd ~/Desktop"
alias r="cd ~/Repos"
alias g="git"

# Detect GNU `ls` support
if ls --color=auto >/dev/null 2>&1; then
    colorflag="--color=auto"
else
    colorflag=""
fi

# Directory listings
alias l="ls -lF ${colorflag}"
alias la="ls -lAF ${colorflag}"
alias lsd="ls -lF ${colorflag} | grep --color=never '^d'"
alias ll="ls -lathr ${colorflag}"
alias ls="command ls ${colorflag}"

# Always use color with grep family
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# Enable aliases to be sudo’ed
alias sudo='sudo '

# System helpers
alias week='date +%V'
alias update='sudo apt update && sudo apt full-upgrade -y && sudo apt autoremove -y && sudo apt autoclean'
alias localip="hostname -I | awk '{print \$1}'"
alias ips='ip -brief addr show'
alias flush='sudo resolvectl flush-caches'

# Browsers and clipboard
alias chrome='google-chrome'
if command -v wl-copy >/dev/null 2>&1 && command -v wl-paste >/dev/null 2>&1; then
    alias pbcopy='wl-copy'
    alias pbpaste='wl-paste'
elif command -v xclip >/dev/null 2>&1; then
    alias pbcopy='xclip -selection clipboard'
    alias pbpaste='xclip -selection clipboard -o'
elif command -v xsel >/dev/null 2>&1; then
    alias pbcopy='xsel --clipboard --input'
    alias pbpaste='xsel --clipboard --output'
fi
alias c="tr -d '\n' | pbcopy"

# Process and session helpers
alias chromekill="pkill -f 'chrome --type=renderer'"
alias afk='loginctl lock-session'

# Miscellaneous
command -v hd >/dev/null || alias hd='hexdump -C'
alias map='xargs -n1'
alias reload="exec ${SHELL} -l"
alias path='echo -e ${PATH//:/\\n}'
alias cleanup="find . -type f -name '*.DS_Store' -delete"

unset colorflag
