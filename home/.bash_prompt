#!/usr/bin/env bash

# Shell prompt based on the Solarized Dark theme with modern terminal features
# Optimized for GPU-accelerated terminals and Nerd Fonts

if [[ $COLORTERM = gnome-* && $TERM = xterm ]] && infocmp gnome-256color >/dev/null 2>&1; then
	export TERM='gnome-256color';
elif infocmp xterm-256color >/dev/null 2>&1; then
	export TERM='xterm-256color';
fi;

# Enable true color support if available
if [[ $COLORTERM =~ ^(truecolor|24bit)$ ]]; then
    export COLORTERM=truecolor
fi

if tput setaf 1 &> /dev/null; then
	tput sgr0; # reset colors
	bold=$(tput bold);
	reset=$(tput sgr0);
	# Solarized colors with true color support
	black=$(tput setaf 8);
	blue=$(tput setaf 69);
	cyan=$(tput setaf 37);
	green=$(tput setaf 64);
	orange=$(tput setaf 130);
	purple=$(tput setaf 140);
	red=$(tput setaf 224);
	pink=$(tput setaf 218);  # light pink
	white=$(tput setaf 15);
	yellow=$(tput setaf 100);
else
	bold='';
	reset="\e[0m";
	black="\e[1;30m";
	blue="\e[1;34m";
	cyan="\e[1;36m";
	green="\e[1;32m";
	orange="\e[1;33m";
	purple="\e[1;35m";
	red="\e[1;31m";
	pink="\e[1;38;5;218m";  # light pink
	white="\e[1;37m";
	yellow="\e[1;33m";
fi;

# Git prompt symbols (ASCII for broad compatibility)
gitBranchLabel='git:'
gitDirtySymbol='*'
gitCleanSymbol='-'
gitAheadSymbol='>'
gitBehindSymbol='<'
gitDivergedSymbol='!'

prompt_prev() {
	local exit_code=$?;
	if [ $exit_code -ne 0 ]; then
		printf " \\[%b\\]!%d\\[%b\\]" "${red}" "$exit_code" "${reset}";
	else
		printf " \\[%b\\]ok\\[%b\\]" "${green}" "${reset}";
	fi;
}
# Show repo-relative path when inside Git, otherwise a home-shortened absolute path.
prompt_path() {
	local path='';
	if git rev-parse --is-inside-work-tree &>/dev/null; then
		path=$(git rev-parse --show-prefix 2>/dev/null);
		printf "\\[%b\\]%s\\[%b\\]" "${purple}" "${path:-./}" "${reset}";
	else
		path="${PWD/#$HOME/~}";
		printf "\\[%b\\]%s\\[%b\\]" "${purple}" "$path" "${reset}";
	fi;
}

# Print a single-line git summary with branch, change, and upstream indicators.
prompt_git_info() {
	local branchName='';
	local branchDisplay='';
	local statusOutput='';
	local changeIndicator='';
	local remoteIndicator='';
	local upstream='';
	local ahead=0;
	local behind=0;

	git rev-parse --is-inside-work-tree &>/dev/null || return;

	branchName="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || \
		git describe --all --exact-match HEAD 2>/dev/null || \
		git rev-parse --short HEAD 2>/dev/null || \
		echo '(unknown)')";

	branchDisplay="$branchName";
	if [ ${#branchDisplay} -gt 75 ]; then
		branchDisplay="${branchDisplay:0:72}...";
	fi;

	statusOutput="$(git status --porcelain --ignore-submodules 2>/dev/null)";
	if [ -n "$statusOutput" ]; then
		changeIndicator="\\[${yellow}\\]${gitDirtySymbol}\\[${reset}\\]";
	else
		changeIndicator="\\[${green}\\]${gitCleanSymbol}\\[${reset}\\]";
	fi;

	upstream="$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null)";
	if [ -n "$upstream" ]; then
		ahead=$(git rev-list --count "${upstream}..HEAD" 2>/dev/null || echo 0);
		behind=$(git rev-list --count "HEAD..${upstream}" 2>/dev/null || echo 0);
		if [ "$ahead" -gt 0 ] && [ "$behind" -gt 0 ]; then
			remoteIndicator="\\[${yellow}\\]${gitDivergedSymbol}\\[${reset}\\]";
		elif [ "$ahead" -gt 0 ]; then
			remoteIndicator="\\[${green}\\]${gitAheadSymbol}\\[${reset}\\]";
		elif [ "$behind" -gt 0 ]; then
			remoteIndicator="\\[${red}\\]${gitBehindSymbol}\\[${reset}\\]";
		fi;
	fi;

	printf "\\[%b\\]%s %s\\[%b\\]" "${cyan}" "${gitBranchLabel}" "${branchDisplay}" "${reset}";
	printf " %s" "$changeIndicator";
	if [ -n "$remoteIndicator" ]; then
		printf " %s" "$remoteIndicator";
	fi;
	printf "\n";
}
# Set the terminal title and prompt.
PS1="";
PS1+="\$(prompt_git_info)";
PS1+="\$(prompt_path)";
PS1+="\$(prompt_prev) ";
PS1+="\[$yellow\]>\[$reset\] ";
export PS1;

# Secondary prompt for command continuation
PS2="\[$yellow\]->\[$reset\] ";
export PS2;
