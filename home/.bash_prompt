#!/usr/bin/env bash

# Shell prompt based on the Solarized Dark theme with modern terminal features
# Optimized for GPU-accelerated terminals and Nerd Fonts

if [[ $COLORTERM = gnome-* && $TERM = xterm ]] && infocmp gnome-256color >/dev/null 2>&1; then
	export TERM='gnome-256color';
elif infocmp xterm-256color >/dev/null 2>&1; then
	export TERM='xterm-256color';
fi;

# Enable true color support if available
if [[ $COLORTERM =~ ^(truecolor|24bit)$ ]]; then
    export COLORTERM=truecolor
fi

if tput setaf 1 &> /dev/null; then
	tput sgr0; # reset colors
	bold=$(tput bold);
	reset=$(tput sgr0);
	# Solarized colors with true color support
	black=$(tput setaf 8);
	blue=$(tput setaf 69);
	cyan=$(tput setaf 37);
	green=$(tput setaf 64);
	orange=$(tput setaf 130);
	purple=$(tput setaf 140);
	red=$(tput setaf 224);
	pink=$(tput setaf 218);  # light pink
	white=$(tput setaf 15);
	yellow=$(tput setaf 100);
else
	bold='';
	reset="\e[0m";
	black="\e[1;30m";
	blue="\e[1;34m";
	cyan="\e[1;36m";
	green="\e[1;32m";
	orange="\e[1;33m";
	purple="\e[1;35m";
	red="\e[1;31m";
	pink="\e[1;38;5;218m";  # light pink
	white="\e[1;37m";
	yellow="\e[1;33m";
fi;

# Git status symbols (using actual Unicode characters)
gitStagedSymbol='✅'     # check mark button
gitUnstagedSymbol='❌'   # cross mark
gitUntrackedSymbol='🆕'  # new button
gitStashSymbol='📦'     # package/box
gitAheadSymbol='⬆️'     # up arrow
gitBehindSymbol='⬇️'    # down arrow
gitDivergedSymbol='🔄'  # arrows counterclockwise
gitCleanSymbol='✨'     # sparkles
gitDirtySymbol='💫'     # dizzy
gitBranchSymbol='🌿'    # herb/leaf
gitTagSymbol='🏷️'      # label
gitArrowSymbol='➡️'     # right arrow

prompt_prev() {
	local exit_code=$?;
	if [ $exit_code -ne 0 ]; then
		printf " %b%b %d%b" "${red}" "${gitUnstagedSymbol}" "$exit_code" "${reset}";
	else
		printf " %b%b%b" "${green}" "${gitCleanSymbol}" "${reset}";
	fi;
}

prompt_jobs() {
	local jobs=$(jobs -l | wc -l);
	if [ $jobs -gt 0 ]; then
		printf " %b⚙%b" "${yellow}" "${reset}"; # gear
	fi;
}

prompt_git_branch() {
    local branchName='';
    local ahead=0;
    local behind=0;
    local s='';

    # Check if the current directory is in a Git repository.
    git rev-parse --is-inside-work-tree &>/dev/null || return;

    # Get branch name
    branchName="$(git symbolic-ref --quiet --short HEAD 2> /dev/null || \
        git describe --all --exact-match HEAD 2> /dev/null || \
        git rev-parse --short HEAD 2> /dev/null || \
        echo '(unknown)')";

    # Check for changes and build status string
    local hasChanges=false;
    
    # Check for staged changes
    if ! $(git diff --quiet --ignore-submodules --cached); then
        s+="${white}${gitStagedSymbol}";
        hasChanges=true;
    fi;
    
    # Check for unstaged changes
    if ! $(git diff-files --quiet --ignore-submodules --); then
        s+="${green}${gitUnstagedSymbol}";
        hasChanges=true;
    fi;
    
    # Check for untracked files
    if [ -n "$(git ls-files --others --exclude-standard)" ]; then
        s+="${cyan}${gitUntrackedSymbol}";
        hasChanges=true;
    fi;
    
    # Check for stashed changes
    if $(git rev-parse --verify refs/stash &>/dev/null); then
        s+="${orange}${gitStashSymbol}";
        hasChanges=true;
    fi;

    # Check for remote status
    if [ -n "$(git rev-parse --abbrev-ref @{upstream} 2>/dev/null)" ]; then
        ahead=$(git rev-list --count @{upstream}..HEAD 2>/dev/null || echo 0);
        behind=$(git rev-list --count HEAD..@{upstream} 2>/dev/null || echo 0);
        
        if [ $ahead -gt 0 ] && [ $behind -gt 0 ]; then
            s+="${pink}${gitDivergedSymbol}";
        elif [ $ahead -gt 0 ]; then
            s+="${green}${gitAheadSymbol}";
        elif [ $behind -gt 0 ]; then
            s+="${red}${gitBehindSymbol}";
        fi;
    fi;

    # If no changes, show clean status
    if [ "$hasChanges" = false ] && [ $ahead -eq 0 ] && [ $behind -eq 0 ]; then
        s="${green}${gitCleanSymbol}";
    fi;

    [ -n "${s}" ] && s="${blue}[${s}${blue}]";

    printf "%b%s%b %s%b%b" \
        "${cyan}" \
        "${gitBranchSymbol} ${branchName}" \
        "${s}" \
        "${reset}" \
				"\n";
}

prompt_git_repo() {
    local repoUrl='';
    local repoHost='';
    local gitRoot='';

    # Check if the current directory is in a Git repository.
    git rev-parse --is-inside-work-tree &>/dev/null || return;

    # Get git root directory
    gitRoot=$(git rev-parse --show-toplevel 2>/dev/null);

    # Get repository URL
    repoUrl="$(git config --get remote.origin.url)";

    # Set repository host symbol
    repoHost="🌿 "  # branch
    if grep -q 'github.com' <<< "${repoUrl}"; then
        repoHost="🏷️ ";  # star
    fi;

    # Store git root for later use
    export __GIT_ROOT="$gitRoot";

    printf "%b%s%s%b" \
        "${pink}" \
        "${repoHost}" \
        "${repoUrl##git*com:}" \
        "${reset}";
}
# Set the terminal title and prompt.
PS1="";
PS1+="\$(prompt_git_branch)\n";
PS1+="\$(prompt_git_repo)"; # Git repository details
PS1+="\$(if git rev-parse --is-inside-work-tree &>/dev/null; then git rev-parse --show-prefix; else echo -n '\w'; fi)"; # Show relative path in git or full path otherwise
PS1+="\$(prompt_prev)\$(prompt_jobs)"
PS1+="\[${yellow}\]>\[${reset}\] ";
export PS1;

PS2="\[${yellow}\]${gitArrowSymbol} \[${reset}\]";
export PS2;
