#!/usr/bin/env bash
# shellcheck shell=bash

# Solarized prompt colors. Keeping these as constants avoids spawning tput once
# per color during every interactive shell startup.
if [[ -t 1 && "${TERM:-dumb}" != dumb ]]; then
    prompt_reset=$'\033[0m'
    prompt_cyan=$'\033[38;5;37m'
    prompt_green=$'\033[38;5;64m'
    prompt_purple=$'\033[38;5;140m'
    prompt_red=$'\033[38;5;224m'
    prompt_yellow=$'\033[38;5;100m'
else
    prompt_reset=''
    prompt_cyan=''
    prompt_green=''
    prompt_purple=''
    prompt_red=''
    prompt_yellow=''
fi

prompt_np_start=$'\001'
prompt_np_end=$'\002'
prompt_cyan_ps="${prompt_np_start}${prompt_cyan}${prompt_np_end}"
prompt_green_ps="${prompt_np_start}${prompt_green}${prompt_np_end}"
prompt_purple_ps="${prompt_np_start}${prompt_purple}${prompt_np_end}"
prompt_red_ps="${prompt_np_start}${prompt_red}${prompt_np_end}"
prompt_reset_ps="${prompt_np_start}${prompt_reset}${prompt_np_end}"
prompt_yellow_ps="${prompt_np_start}${prompt_yellow}${prompt_np_end}"

# Render all dynamic prompt state in one expansion so the previous command's
# exit status is not replaced by an earlier prompt command substitution.
__prompt_render() {
    local exit_code="${1:-0}"
    local status_output='' repo_output='' repo_root='' repo_prefix=''
    local branch='' oid='' line='' ahead=0 behind=0 dirty=0
    local path="${PWD/#${HOME}/\~}" title='' remote_indicator=''

    if status_output="$(command git status --porcelain=v2 --branch --ignore-submodules 2>/dev/null)"; then
        while IFS= read -r line; do
            case "${line}" in
                '# branch.oid '*) oid="${line#\# branch.oid }" ;;
                '# branch.head '*) branch="${line#\# branch.head }" ;;
                '# branch.ab '*)
                    line="${line#\# branch.ab }"
                    ahead="${line%% *}"
                    behind="${line##* }"
                    ahead="${ahead#+}"
                    behind="${behind#-}"
                    ;;
                '# '|'') ;;
                *) dirty=1 ;;
            esac
        done <<<"${status_output}"

        repo_output="$(command git rev-parse --show-toplevel --show-prefix 2>/dev/null)"
        repo_root="${repo_output%%$'\n'*}"
        if [[ "${repo_output}" == *$'\n'* ]]; then
            repo_prefix="${repo_output#*$'\n'}"
        fi
        path="${repo_prefix:-./}"

        if [[ -z "${branch}" || "${branch}" == '(detached)' ]]; then
            branch="${oid:0:7}"
        fi
        [[ ${#branch} -gt 75 ]] && branch="${branch:0:72}..."

        if ((ahead > 0 && behind > 0)); then
            remote_indicator="${prompt_yellow_ps}!${prompt_reset_ps}"
        elif ((ahead > 0)); then
            remote_indicator="${prompt_green_ps}>${prompt_reset_ps}"
        elif ((behind > 0)); then
            remote_indicator="${prompt_red_ps}<${prompt_reset_ps}"
        fi

        printf '%sgit:%s %s%s' "${prompt_cyan_ps}" "${prompt_reset_ps}" \
            "${branch}" "${prompt_reset_ps}"
        if ((dirty)); then
            printf ' %s*%s' "${prompt_yellow_ps}" "${prompt_reset_ps}"
        else
            printf ' %s-%s' "${prompt_green_ps}" "${prompt_reset_ps}"
        fi
        [[ -n "${remote_indicator}" ]] && printf ' %s' "${remote_indicator}"
        printf '\n'
    fi

    if [[ "${TERM_PROGRAM:-}" == 'iTerm.app' ]]; then
        title="${repo_root##*/}"
        [[ -z "${title}" ]] && title="${PWD##*/}"
        printf '\033]0;%s\007' "${title}"
    fi

    printf '%s%s%s' "${prompt_purple_ps}" "${path}" "${prompt_reset_ps}"
    if ((exit_code != 0)); then
        printf ' %s!%d%s' "${prompt_red_ps}" "${exit_code}" "${prompt_reset_ps}"
    else
        printf ' %sok%s' "${prompt_green_ps}" "${prompt_reset_ps}"
    fi
    printf ' %s>%s ' "${prompt_yellow_ps}" "${prompt_reset_ps}"
}

PS1='$(__prompt_render $?)'
PS2="${prompt_np_start}${prompt_yellow}${prompt_np_end}->${prompt_np_start}${prompt_reset}${prompt_np_end} "
export PS1 PS2
